# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
EXPO_PUBLIC_SENTRY_DSN=https://your_key@oXXX.ingest.us.sentry.io/YYYY

# Firebase — create a project at console.firebase.google.com and copy from Project Settings
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth — create OAuth 2.0 credentials at console.cloud.google.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
