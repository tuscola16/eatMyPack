{
  "expo": {
    "name": "eatMyPack",
    "slug": "eatmypack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "eatmypack",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1F16"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eatmypack.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1F16"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.eatmypack.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-web-browser",
      "expo-font"
    ]
  }
}
