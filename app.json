{
  "expo": {
    "name": "eatMyPack",
    "slug": "eat-my-pack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "eatmypack",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7aeb7c2c-bb8c-4286-8d52-866d8b66ce36",
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1F16"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eatmypack.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "appleTeamId": "GVJ7DFUGUX",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1F16"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.eatmypack.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-web-browser",
      "expo-font",
      "expo-updates",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "eat-my-pack",
          "organization": "bagel-runs-technology"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7aeb7c2c-bb8c-4286-8d52-866d8b66ce36"
      },
      "router": {}
    },
    "owner": "bagel-run-technologies"
  }
}
